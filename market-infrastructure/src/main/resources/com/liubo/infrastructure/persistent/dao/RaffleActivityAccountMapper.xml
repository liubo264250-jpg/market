<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.liubo.infrastructure.persistent.dao.RaffleActivityAccountMapper">

    <resultMap id="BaseResultMap" type="com.liubo.infrastructure.persistent.po.RaffleActivityAccount">
            <id property="id" column="id" />
            <result property="userId" column="user_id" />
            <result property="activityId" column="activity_id" />
            <result property="totalCount" column="total_count" />
            <result property="totalCountSurplus" column="total_count_surplus" />
            <result property="dayCount" column="day_count" />
            <result property="dayCountSurplus" column="day_count_surplus" />
            <result property="monthCount" column="month_count" />
            <result property="monthCountSurplus" column="month_count_surplus" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,activity_id,total_count,total_count_surplus,day_count,
        day_count_surplus,month_count,month_count_surplus,create_time,update_time
    </sql>
    <update id="updateActivityAccountSubtractionQuota">
        update raffle_activity_account
        set total_count_surplus = total_count_surplus - 1,
            day_count_surplus   = day_count_surplus - 1,
            month_count_surplus = month_count_surplus - 1,
            update_time         = now()
        where user_id = #{userId}
          and activity_id = #{activityId}
          and total_count_surplus > 0
          and day_count_surplus > 0
          and month_count_surplus > 0
    </update>
    <update id="updateActivityAccountMonthSurplusImageQuota">
        update raffle_activity_account
        set month_count_surplus = #{monthCountSurplus} - 1,
            update_time         = now()
        where user_id = #{userId}
          and activity_id = #{activityId}
    </update>
    <update id="updateActivityAccountDaySurplusImageQuota">
        update raffle_activity_account
        set day_count_surplus = #{dayCountSurplus} - 1,
            update_time         = now()
        where user_id = #{userId}
          and activity_id = #{activityId}
    </update>
</mapper>
